# Admin key — required to access /admin/appointments and GET /api/appointments.
# Set this to a long, random secret before deploying (e.g. openssl rand -hex 32).
ADMIN_API_KEY=toothfairy

# Neon Postgres connection string.
# On Vercel: added automatically when you attach the Neon integration.
# Locally:   run `vercel env pull .env.local` after linking the project.
POSTGRES_URL=postgres://user:password@host.neon.tech/dbname?sslmode=require
